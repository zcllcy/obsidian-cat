{
  "name": "obsidian-cat",
  "version": "0.1.0",
  "private": true,
  "description": "An Obsidian plugin with a bundled desktop cat companion for research-vault ingestion and maintenance.",
  "main": "apps/desktop/main.js",
  "scripts": {
    "agent": "node src/node_agent.js",
    "desktop": "electron .",
    "plugin:check": "node --check obsidian-plugin/obsidian-cat/main.js && node --check src/node_agent.js && node --check apps/desktop/main.js",
    "plugin:bundle-runtime": "powershell -ExecutionPolicy Bypass -File obsidian-plugin/obsidian-cat/package-runtime.ps1",
    "dist:win": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^38.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "research.lcy.obsidian-cat",
    "productName": "Obsidian Cat",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "apps/**/*",
      "public/**/*",
      "src/**/*",
      "config/agent.config.example.json",
      "README.md",
      "DESKTOP_APP_NOTES.md"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Obsidian Cat"
    }
  }
}
